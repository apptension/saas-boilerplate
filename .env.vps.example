# =============================================================================
# VPS/SELF-HOSTED ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains the environment variables for docker-compose.prod.yml
# Used for deploying to VPS providers (Hetzner, DigitalOcean, Linode, etc.)
#
# Quick Start:
#   1. Copy this file: cp .env.vps.example .env.prod
#   2. Update all placeholder values
#   3. Run: docker compose -f docker-compose.prod.yml up -d
#
# For detailed guidance, see: packages/internal/docs/docs/deployment/vps.mdx
# =============================================================================

# -----------------------------------------------------------------------------
# DOMAIN CONFIGURATION (Required)
# -----------------------------------------------------------------------------
# Your domain must be pointed to your VPS IP address before deployment

# Your main domain (webapp will be at this domain, API at api.DOMAIN)
DOMAIN=example.com

# Email address for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# REQUIRED SECRETS (Generate unique values!)
# -----------------------------------------------------------------------------

# Django secret key - used for cryptographic signing
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=<GENERATE_ME>

# Salt for HashID field encoding
# Generate with: openssl rand -hex 32
HASHID_FIELD_SALT=<GENERATE_ME>

# PostgreSQL password (used for database container)
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=<GENERATE_ME>

# -----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# -----------------------------------------------------------------------------
# Choose your storage backend

# Options: local, r2, b2, minio, s3
# - local: Store files on VPS filesystem (default, simplest)
# - r2: Cloudflare R2 (S3-compatible, cheap storage)
# - b2: Backblaze B2 (S3-compatible)
# - minio: Self-hosted MinIO
# - s3: AWS S3
STORAGE_BACKEND=local

# --- Cloudflare R2 (if STORAGE_BACKEND=r2) ---
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# --- Backblaze B2 (if STORAGE_BACKEND=b2) ---
# B2_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
# B2_ACCESS_KEY_ID=
# B2_SECRET_ACCESS_KEY=
# B2_BUCKET_NAME=

# --- MinIO (if STORAGE_BACKEND=minio) ---
# MINIO_ENDPOINT_URL=http://minio:9000
# MINIO_ACCESS_KEY_ID=
# MINIO_SECRET_ACCESS_KEY=
# MINIO_BUCKET_NAME=

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Choose your email backend

# Options:
# - django.core.mail.backends.smtp.EmailBackend (default, generic SMTP)
# - sendgrid_backend.SendgridBackend (SendGrid)
# - django_ses.SESBackend (AWS SES)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Sender email address (must match your SMTP/provider configuration)
EMAIL_FROM_ADDRESS=noreply@example.com

# --- Generic SMTP (if using SMTP backend) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# --- SendGrid (if EMAIL_BACKEND=sendgrid_backend.SendgridBackend) ---
# SENDGRID_API_KEY=SG.xxxxxxxx

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS (Optional)
# -----------------------------------------------------------------------------
# Skip if not using payments. You can add these later.

# Start with test keys, switch to live when ready
STRIPE_TEST_SECRET_KEY=sk_test_<CHANGE_ME>
STRIPE_LIVE_SECRET_KEY=sk_live_<CHANGE_ME>
STRIPE_LIVE_MODE=False

# Webhook signing secret
# Webhook URL: https://api.DOMAIN/subscriptions/stripe-webhook/
DJSTRIPE_WEBHOOK_SECRET=whsec_<CHANGE_ME>

# -----------------------------------------------------------------------------
# OAUTH / SOCIAL LOGIN (Optional)
# -----------------------------------------------------------------------------

# Google OAuth2
# Redirect URI: https://api.DOMAIN/auth/social/complete/google-oauth2/
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Facebook OAuth
# Redirect URI: https://api.DOMAIN/auth/social/complete/facebook/
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=

# -----------------------------------------------------------------------------
# AI FEATURES (Optional)
# -----------------------------------------------------------------------------

# OpenAI API key
OPENAI_API_KEY=

# OpenAI model
# OPENAI_MODEL=gpt-4

# -----------------------------------------------------------------------------
# MONITORING (Optional but Recommended)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=

# -----------------------------------------------------------------------------
# ADVANCED FEATURES (Optional)
# -----------------------------------------------------------------------------

# 2FA issuer name shown in authenticator apps
OTP_AUTH_ISSUER_NAME=YourAppName

# Celery worker configuration
# CELERY_WORKER_CONCURRENCY=2
# CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# Traefik dashboard authentication (htpasswd format)
# Generate with: htpasswd -nb admin your-password
# TRAEFIK_DASHBOARD_AUTH=admin:$apr1$xxxxx

# WebSocket support (for real-time features)
# WEB_SOCKET_API_ENDPOINT_URL=

# Translation CDN
# TRANSLATIONS_BUCKET_NAME=
# TRANSLATIONS_CLOUDFRONT_ID=
