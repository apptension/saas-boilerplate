# Component Patterns

## Functional Components with Types

Always define and export prop types:

```tsx
export type ComponentNameProps = {
  requiredProp: string;
  optionalProp?: boolean;
  onAction?: () => void;
};

export const ComponentName = ({ requiredProp, optionalProp = false, onAction }: ComponentNameProps) => {
  // Component implementation
};
```

## UI Components

Use shadcn/ui components from `@sb/webapp-core/components/ui/`:

```tsx
import { Button } from '@sb/webapp-core/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@sb/webapp-core/components/ui/card';
import { Dialog, DialogContent, DialogTrigger } from '@sb/webapp-core/components/ui/dialog';
import { Tooltip, TooltipContent, TooltipTrigger } from '@sb/webapp-core/components/ui/tooltip';
import { Avatar, AvatarImage, AvatarFallback } from '@sb/webapp-core/components/ui/avatar';
```

## Tooltip Pattern for Collapsed States

Wrap interactive elements with tooltips when in collapsed state:

```tsx
{isCollapsed ? (
  <Tooltip delayDuration={200}>
    <TooltipTrigger asChild>{content}</TooltipTrigger>
    <TooltipContent side="right">{label}</TooltipContent>
  </Tooltip>
) : (
  content
)}
```

## Context Usage

Use React Context for shared state:

```tsx
import { useContext } from 'react';
import { LayoutContext } from '../layout.context';

const { isSidebarCollapsed, toggleSidebar } = useContext(LayoutContext);
```

## Responsive Behavior

Use the `useMediaQuery` hook:

```tsx
import { useMediaQuery } from '@sb/webapp-core/hooks';
import { media } from '@sb/webapp-core/theme';

const { matches: isDesktop } = useMediaQuery({
  above: media.Breakpoint.TABLET,
});

// Combine with collapsed state
const isCollapsedDesktop = isSidebarCollapsed && isDesktop;
```

## Inline Action Buttons

For small inline action buttons (like resend, refresh, retry):

```tsx
import { RefreshCw } from 'lucide-react';

<Button
  variant="outline"
  size="sm"
  className="h-6 px-2 text-xs"
  onClick={handleAction}
  disabled={loading}
>
  <RefreshCw className={`h-3 w-3 mr-1 ${loading ? 'animate-spin' : ''}`} />
  <FormattedMessage id="Feature / Action" defaultMessage="Resend" />
</Button>
```

Key points:
- Use `variant="outline"` for visibility with border
- Use `size="sm"` with custom `className="h-6 px-2 text-xs"` for compact size
- Add spinning animation on loading: `${loading ? 'animate-spin' : ''}`
- Disable button during loading: `disabled={loading}`

## Conditional Rendering with Actions

Show different UI based on state with optional actions:

```tsx
{condition ? (
  <div className="flex items-center">
    <CheckIcon className="mr-2 w-4 h-4" />
    <FormattedMessage id="Feature / Yes" defaultMessage="Yes" />
  </div>
) : (
  <div className="flex items-center gap-2">
    <PendingIcon className="mr-2 w-4 h-4" />
    <FormattedMessage id="Feature / No" defaultMessage="No" />
    <ActionButton onClick={handleAction} loading={loading} />
  </div>
)}
```

## Multiple Mutations in One Component

When a component needs multiple mutations:

```tsx
const [commitUpdateMutation, { loading: updateLoading }] = useMutation(updateMutation, {
  onCompleted: () => toast({ description: updateSuccessMessage, variant: 'success' }),
  onError: () => toast({ description: updateFailMessage, variant: 'destructive' }),
});

const [commitDeleteMutation] = useMutation(deleteMutation, {
  onCompleted: () => {
    toast({ description: deleteSuccessMessage, variant: 'success' });
    onAfterUpdate?.();
  },
  onError: () => toast({ description: deleteFailMessage, variant: 'destructive' }),
});

const [commitResendMutation, { loading: resendLoading }] = useMutation(resendMutation, {
  onCompleted: () => toast({ description: resendSuccessMessage, variant: 'success' }),
  onError: () => toast({ description: resendFailMessage, variant: 'destructive' }),
});
```

Define all i18n messages at the top of the component:

```tsx
const updateSuccessMessage = intl.formatMessage({
  id: 'Feature / Update / Success',
  defaultMessage: 'Updated successfully!',
});

const resendSuccessMessage = intl.formatMessage({
  id: 'Feature / Resend / Success',
  defaultMessage: 'Resent successfully!',
});
```
