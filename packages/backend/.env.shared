# =============================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains shared backend configuration that's safe to commit.
# For secrets and personal overrides, create a `.env` file in this directory.
#
# Quick Start:
#   1. Copy this file: cp .env.shared .env
#   2. Generate new values for DJANGO_SECRET_KEY and HASHID_FIELD_SALT
#   3. Update ADMIN_EMAIL and ADMIN_DEFAULT_PASSWORD
#
# Generate secure keys with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50)[:50])"
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS (Required)
# -----------------------------------------------------------------------------

# Enable debug mode (set to "off" in production!)
# https://docs.djangoproject.com/en/4.2/ref/settings/#debug
DJANGO_DEBUG=on

# Allowed CIDR networks for internal services (leave empty for local dev)
DJANGO_ALLOWED_CIDR_NETS=

# Allowed hosts that can serve the application
# Use specific domains in production, "*" only for local development
DJANGO_ALLOWED_HOSTS=*

# Default hostname for URL generation
DJANGO_DEFAULT_HOST=localhost

# IMPORTANT: Generate a unique 50-character secret key for your project!
# This is used for cryptographic signing (sessions, tokens, etc.)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50)[:50])"
DJANGO_SECRET_KEY=X&*az9nsBNykh!hXMczbaeH2oAm%jR6ZalWcXDW0#PUjHn0Xjs

# IMPORTANT: Generate a unique salt for HashID field encoding!
# This is used to encode/decode database IDs in URLs
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50)[:50])"
HASHID_FIELD_SALT=X&*az9nsBNykh!hXMczbaeH2oAm%jR6ZalWcXDW0#PUjHn0Xjs

# Environment name (local, staging, production, etc.)
ENVIRONMENT_NAME=local

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# DJANGO_LOG_LEVEL=INFO

# Parent host for django-hosts (used in production with subdomains)
# PARENT_HOST=example.com

# CSRF trusted origins (comma-separated list of origins)
# CSRF_TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com

# -----------------------------------------------------------------------------
# ADMIN ACCOUNT (Required)
# -----------------------------------------------------------------------------
# Credentials for the initial superadmin account created on first run
# You can log in at http://admin.localhost:5001 with these credentials

ADMIN_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=password

# -----------------------------------------------------------------------------
# DATABASE & CACHE (Local Development Defaults)
# -----------------------------------------------------------------------------
# These connect to the Docker containers defined in docker-compose.yml
# No changes needed for local development

# PostgreSQL connection (JSON format)
DB_CONNECTION={"dbname":"backend","username":"backend","password":"backend","host":"db","port":5432}

# RDS Proxy endpoint (AWS production only, overrides host in DB_CONNECTION)
# DB_PROXY_ENDPOINT=

# Redis connection for caching and Celery
REDIS_CONNECTION=redis://redis:6379

# -----------------------------------------------------------------------------
# WORKERS INTEGRATION
# -----------------------------------------------------------------------------
# Configuration for connecting to the Lambda workers service

# Local workers URL (Docker container)
LAMBDA_TASKS_LOCAL_URL=http://workers:3005

# Task handler for local development (uses HTTP instead of Lambda)
LAMBDA_TASKS_BASE_HANDLER=common.tasks.LambdaTaskLocalInvoke

# Event bus name for workers
WORKERS_EVENT_BUS_NAME=local-workers

# -----------------------------------------------------------------------------
# JWT & AUTHENTICATION
# -----------------------------------------------------------------------------

# Set to True in production (requires HTTPS)
JWT_AUTH_COOKIE_SECURE=False

# Access token lifetime in minutes (short for security)
ACCESS_TOKEN_LIFETIME_MINUTES=5

# Refresh token lifetime in days
REFRESH_TOKEN_LIFETIME_DAYS=7

# Issuer name shown in 2FA authenticator apps
OTP_AUTH_ISSUER_NAME=example.com

# OTP token lifetime in minutes (how long the OTP verification step is valid)
# OTP_AUTH_TOKEN_LIFETIME_MINUTES=5

# -----------------------------------------------------------------------------
# OAUTH / SOCIAL LOGIN (Optional)
# Set these to enable Google/Facebook login
# -----------------------------------------------------------------------------

# Allowed redirect hosts after OAuth (comma-separated)
SOCIAL_AUTH_ALLOWED_REDIRECT_HOSTS=localhost:3000

# Set to True if webapp is served over HTTPS
SOCIAL_AUTH_REDIRECT_IS_HTTPS=False

# Google OAuth2 credentials
# Get from: https://console.cloud.google.com/apis/credentials
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=<CHANGE_ME>
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=<CHANGE_ME>

# Facebook OAuth credentials
# Get from: https://developers.facebook.com/apps/
SOCIAL_AUTH_FACEBOOK_KEY=<CHANGE_ME>
SOCIAL_AUTH_FACEBOOK_SECRET=<CHANGE_ME>

# -----------------------------------------------------------------------------
# SSO CONFIGURATION (Optional - Enterprise)
# Set these for SAML/OIDC single sign-on
# -----------------------------------------------------------------------------

# Base URL for Service Provider Entity ID (e.g., https://api.yourdomain.com)
# SSO_SP_ENTITY_ID_BASE=

# Web application URL (used for SSO redirects)
# WEB_APP_URL=http://localhost:3000

# API URL (used for SSO metadata)
# API_URL=http://localhost:5001

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS (Optional)
# Set these to enable payment/subscription features
# Get keys from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------

# Enable Stripe integration checks (set to False to disable payments)
STRIPE_CHECKS_ENABLED=True

# Stripe API keys (start with sk_live_ or sk_test_)
STRIPE_LIVE_SECRET_KEY=sk_<CHANGE_ME>
STRIPE_TEST_SECRET_KEY=sk_test_<CHANGE_ME>

# Use test mode for local development
STRIPE_LIVE_MODE=False

# Webhook secret for validating Stripe events
# Get from: https://dashboard.stripe.com/webhooks
DJSTRIPE_WEBHOOK_SECRET=whsec_<CHANGE_ME>

# Number of trial days for new subscriptions (default: 7)
# SUBSCRIPTION_TRIAL_PERIOD_DAYS=7

# -----------------------------------------------------------------------------
# AWS STORAGE & SERVICES
# -----------------------------------------------------------------------------
# For local development, these use LocalStack or mock values
# In production, set actual S3 bucket names

AWS_STORAGE_BUCKET_NAME=test-bucket
AWS_EXPORTS_STORAGE_BUCKET_NAME=exports-bucket

# Disable AWS X-Ray for local development
AWS_XRAY_SDK_ENABLED=False

# AWS region for services
# AWS_REGION=eu-west-1

# Custom S3 endpoint URL (for LocalStack or compatible services)
# AWS_ENDPOINT_URL=

# CloudFront settings for signed URLs
# AWS_CLOUDFRONT_KEY=
# AWS_CLOUDFRONT_KEY_ID=

# Custom S3 domain (e.g., CloudFront distribution)
# AWS_S3_CUSTOM_DOMAIN=

# S3 presigned URL expiry time in seconds (default: 24 hours)
# AWS_QUERYSTRING_EXPIRE=86400

# User data export link expiry in seconds (default: 2 days)
# USER_DATA_EXPORT_EXPIRY_SECONDS=172800

# Storage (Cloudflare R2)
# STORAGE_BACKEND=r2
# R2_ENDPOINT_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=


# -----------------------------------------------------------------------------
# WEBSOCKETS (Optional)
# For real-time features like notifications
# -----------------------------------------------------------------------------

# WebSocket API Gateway endpoint URL (AWS production)
# WEB_SOCKET_API_ENDPOINT_URL=

# -----------------------------------------------------------------------------
# AI INTEGRATION (Optional)
# Set to enable OpenAI-powered features
# -----------------------------------------------------------------------------

# OpenAI API key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<CHANGE_ME>

# Model to use (gpt-3.5-turbo-instruct, gpt-4, gpt-4-turbo, etc.)
OPENAI_MODEL=gpt-3.5-turbo-instruct

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# For local development, emails are caught by Mailcatcher
# View emails at: http://localhost:1080

# Email backend (use console for logs, smtp for Mailcatcher, ses for production)
# Options:
#   - django.core.mail.backends.console.EmailBackend (logs to console)
#   - django.core.mail.backends.smtp.EmailBackend (Mailcatcher or SMTP)
#   - django_ses.SESBackend (AWS SES for production)
#   - sendgrid_backend.SendgridBackend (SendGrid)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SendGrid settings (used when EMAIL_BACKEND=sendgrid_backend.SendgridBackend)
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_SANDBOX_MODE_IN_DEBUG=false

# SMTP server settings (Mailcatcher for local development)
EMAIL_HOST=mailcatcher
EMAIL_PORT=1025

# Generic SMTP settings (used when EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-username
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=true

# Email addresses for outgoing messages
EMAIL_FROM_ADDRESS=from@example.org
EMAIL_REPLY_ADDRESS=from@example.org

# AWS SES region (defaults to AWS_REGION)
# AWS_SES_REGION_NAME=

# -----------------------------------------------------------------------------
# FILE UPLOADS & DOCUMENTS
# -----------------------------------------------------------------------------

# Maximum upload file size in bytes (default: 10MB)
# UPLOADED_DOCUMENT_SIZE_LIMIT=10485760

# Maximum number of documents per user (default: 10)
# USER_DOCUMENTS_NUMBER_LIMIT=10

# -----------------------------------------------------------------------------
# MULTI-TENANCY
# -----------------------------------------------------------------------------

# Tenant invitation expiry time in seconds (default: 14 days)
# TENANT_INVITATION_TIMEOUT=1209600

# -----------------------------------------------------------------------------
# TRANSLATIONS (Optional)
# For remote translation management
# -----------------------------------------------------------------------------

# S3 bucket for storing translations
# TRANSLATIONS_BUCKET_NAME=

# CloudFront distribution ID for translation CDN
# TRANSLATIONS_CLOUDFRONT_ID=

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY (Optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/
# SENTRY_DSN=

# Sentry trace sample rate (0.0 to 1.0)
# SENTRY_TRACES_SAMPLE_RATE=0.2

# -----------------------------------------------------------------------------
# FLOWER (Celery Monitoring) - Production Only
# -----------------------------------------------------------------------------

# Basic auth for Flower UI (user:password format)
# FLOWER_BASIC_AUTH=admin:password

# Or use OAuth2:
# FLOWER_AUTH_PROVIDER=
# FLOWER_AUTH=
# FLOWER_OAUTH2_KEY=
# FLOWER_OAUTH2_SECRET=
# FLOWER_OAUTH2_REDIRECT_URI=

# -----------------------------------------------------------------------------
# FRONTEND INTEGRATION
# URLs used when generating links in emails
# -----------------------------------------------------------------------------

# URL to email assets (images, etc.)
VITE_EMAIL_ASSETS_URL=http://localhost:3000/email-assets

# Web application URL (used in email links)
VITE_WEB_APP_URL=http://localhost:3000

# URLs (Critical for cross-origin)
# CORS_ALLOWED_ORIGINS=https://webapp-xxxx.onrender.com
# CSRF_TRUSTED_ORIGINS=https://webapp-xxxx.onrender.com,https://backend-api-xxxx.onrender.com

# Backup encryption fallback when AWS Secrets Manager is not used (e.g. Render.com).
# Set to a Fernet key (44-char urlsafe base64). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# BACKUP_MASTER_KEY=