# =============================================================================
# BACKEND ENVIRONMENT CONFIGURATION - RENDER.COM
# =============================================================================
# This file contains the environment variables needed for Render.com deployment.
#
# Quick Start:
#   1. Deploy using the Blueprint (render.yaml) or manually create services
#   2. Copy these variables to Render Dashboard → Environment Variables
#   3. Replace placeholder values with your actual credentials
#
# Variable Types:
#   🔐 = Secret (set in Render Dashboard, never commit real values)
#   ⚙️ = Auto-configured by Render (don't set manually)
#   📝 = Configure after deployment (need your Render URLs)
#   ✅ = Pre-configured in render.yaml (can override if needed)
#
# For detailed guidance, see: packages/internal/docs/docs/deployment/render.mdx
# =============================================================================

# -----------------------------------------------------------------------------
# 🔐 REQUIRED SECRETS (Generate and set in Render Dashboard)
# -----------------------------------------------------------------------------
# These are required for the application to run. Generate unique values!

# Django secret key - used for cryptographic signing (sessions, tokens, etc.)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=<GENERATE_AND_SET_IN_RENDER_DASHBOARD>

# Salt for HashID field encoding - used to encode/decode database IDs in URLs
# Generate with: openssl rand -hex 32
HASHID_FIELD_SALT=<GENERATE_AND_SET_IN_RENDER_DASHBOARD>

# -----------------------------------------------------------------------------
# ⚙️ AUTO-CONFIGURED BY RENDER (Don't set manually)
# -----------------------------------------------------------------------------
# These are automatically injected from other Render services via render.yaml

# DATABASE_URL - PostgreSQL connection string (from postgres service)
# REDIS_CONNECTION - Redis connection string (from redis service)

# -----------------------------------------------------------------------------
# ✅ PRE-CONFIGURED IN RENDER.YAML (Critical settings already set)
# -----------------------------------------------------------------------------

# Platform backends
# STORAGE_BACKEND=r2
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# TASK_BACKEND=celery
# TRACING_BACKEND=none
# DJANGO_DEBUG=False
# ENVIRONMENT_NAME=production

# ⚠️ CRITICAL: Cookie settings for cross-origin authentication
# These are pre-set in render.yaml. Without them, login WILL FAIL!
# COOKIE_SAMESITE=None   # Required for cross-origin cookie access
# COOKIE_SECURE=True     # Required when SameSite=None

# -----------------------------------------------------------------------------
# 📝 URLS (Set after initial deployment - CRITICAL!)
# -----------------------------------------------------------------------------
# After your services are deployed, update these with your actual Render URLs
# You can get these from: Render Dashboard → Your Service → URL

# Your backend API hostname (used in DJANGO_ALLOWED_HOSTS)
# Format: hostname only, NO https:// prefix
# Example: backend-api-xxxx.onrender.com,api.yourdomain.com
DJANGO_ALLOWED_HOSTS=<YOUR_BACKEND_HOSTNAME>

# Your frontend webapp URL (with https://)
# Example: https://webapp-xxxx.onrender.com
WEB_APP_URL=<YOUR_WEBAPP_URL>

# Your backend API URL (with https://)
# Example: https://backend-api-xxxx.onrender.com
API_URL=<YOUR_API_URL>

# ⚠️ CRITICAL FOR CROSS-ORIGIN AUTHENTICATION
# Since webapp and backend are on different Render subdomains, CORS must be configured!
# Without this, login will fail with CORS errors.
# Format: Full URLs with https://, comma-separated
# Example: https://webapp-xxxx.onrender.com
CORS_ALLOWED_ORIGINS=<YOUR_WEBAPP_URL>

# CSRF trusted origins (include both webapp and API)
# Format: Full URLs with https://, comma-separated
# Example: https://webapp-xxxx.onrender.com,https://backend-api-xxxx.onrender.com
CSRF_TRUSTED_ORIGINS=<YOUR_WEBAPP_URL>,<YOUR_API_URL>

# OAuth redirect hosts (for social login)
# Format: Hostnames only, comma-separated
# Example: webapp-xxxx.onrender.com,yourdomain.com
SOCIAL_AUTH_ALLOWED_REDIRECT_HOSTS=<YOUR_WEBAPP_HOSTNAME>

# -----------------------------------------------------------------------------
# 🔐 CLOUDFLARE R2 STORAGE (Required for file uploads)
# -----------------------------------------------------------------------------
# Get credentials from: Cloudflare Dashboard → R2 → Manage R2 API Tokens

# R2 endpoint URL
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=<YOUR_R2_ENDPOINT>

# R2 API access key ID (from API token creation)
R2_ACCESS_KEY_ID=<YOUR_R2_ACCESS_KEY>

# R2 API secret access key (shown only once during token creation!)
R2_SECRET_ACCESS_KEY=<YOUR_R2_SECRET_KEY>

# R2 bucket name
R2_BUCKET_NAME=<YOUR_BUCKET_NAME>

# Optional: Custom domain for public file access (e.g., cdn.yourdomain.com)
# R2_CUSTOM_DOMAIN=

# -----------------------------------------------------------------------------
# 🔐 SENDGRID EMAIL (Required for transactional emails)
# -----------------------------------------------------------------------------
# Get API key from: SendGrid Dashboard → Settings → API Keys

# SendGrid API key (starts with SG.)
SENDGRID_API_KEY=<YOUR_SENDGRID_API_KEY>

# Sender email address (must be verified in SendGrid)
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Optional: Reply-to address (defaults to EMAIL_FROM_ADDRESS)
# EMAIL_REPLY_ADDRESS=support@yourdomain.com

# -----------------------------------------------------------------------------
# 🔐 STRIPE PAYMENTS (Optional - skip if not using payments)
# -----------------------------------------------------------------------------
# Get keys from: Stripe Dashboard → Developers → API Keys
# Webhook secret from: Stripe Dashboard → Developers → Webhooks

# Start with test keys, switch to live when ready
STRIPE_TEST_SECRET_KEY=sk_test_<YOUR_TEST_KEY>
STRIPE_LIVE_SECRET_KEY=sk_live_<YOUR_LIVE_KEY>

# Set to True when ready for production payments
STRIPE_LIVE_MODE=False

# Webhook signing secret (from Stripe webhook endpoint settings)
# Webhook URL: https://your-backend.onrender.com/subscriptions/stripe-webhook/
DJSTRIPE_WEBHOOK_SECRET=whsec_<YOUR_WEBHOOK_SECRET>

# Trial period for new subscriptions (days)
# SUBSCRIPTION_TRIAL_PERIOD_DAYS=7

# -----------------------------------------------------------------------------
# 🔐 OAUTH / SOCIAL LOGIN (Optional)
# -----------------------------------------------------------------------------
# Leave empty if not using social login

# Google OAuth2 (from Google Cloud Console → APIs & Services → Credentials)
# Redirect URI: https://your-backend.onrender.com/auth/social/complete/google-oauth2/
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Facebook OAuth (from Facebook Developers → Your App → Facebook Login → Settings)
# Redirect URI: https://your-backend.onrender.com/auth/social/complete/facebook/
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=

# -----------------------------------------------------------------------------
# 🔐 AI FEATURES (Optional)
# -----------------------------------------------------------------------------
# Leave empty if not using AI features

# OpenAI API key (from platform.openai.com/api-keys)
OPENAI_API_KEY=

# OpenAI model to use
# OPENAI_MODEL=gpt-4

# -----------------------------------------------------------------------------
# 🔐 MONITORING (Optional but Recommended)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking (from sentry.io project settings)
SENTRY_DSN=

# Sentry trace sample rate (0.0 to 1.0, default: 0.2)
# SENTRY_TRACES_SAMPLE_RATE=0.2

# -----------------------------------------------------------------------------
# 🔐 ADVANCED FEATURES (Optional)
# -----------------------------------------------------------------------------

# 2FA issuer name shown in authenticator apps
OTP_AUTH_ISSUER_NAME=YourAppName

# SSO configuration (for enterprise SAML/OIDC)
# SSO_SP_ENTITY_ID_BASE=https://your-backend.onrender.com

# Parent host for django-hosts subdomain routing
# PARENT_HOST=yourdomain.com

# WebSocket support (requires additional Render configuration)
# WEB_SOCKET_API_ENDPOINT_URL=

# Translation CDN (if using remote translations)
# TRANSLATIONS_BUCKET_NAME=
# TRANSLATIONS_CLOUDFRONT_ID=
