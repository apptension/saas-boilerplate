# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local development
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# Ignore Mac/OSX system files
.DS_Store

# Ignore IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore any local backup files
*.bak
*.backup

# Ignore any local environment files
.env
.envrc

# Ignore any local secrets
*.pem
*.key
*.crt
*.p12
*.pfx