terraform {
  required_version = ">= 1.0.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = "~> 2.0"
    }
    helm = {
      source  = "hashicorp/helm"
      version = "~> 2.0"
    }
  }
  backend "s3" {
    bucket         = "__S3_BUCKET_NAME__"
    key            = "global/terraform.tfstate"
    dynamodb_table = "__DYNAMODB_TABLE_NAME__"
    encrypt        = true
  }
}