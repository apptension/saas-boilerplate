class TestAll{{ pascalCase pluralName }}Query:
    """
    Tests for all{{ pascalCase pluralName }} query
    """

    ALL_{{ constantCase pluralName }}_QUERY = '''
        query All{{ pascalCase pluralName }}Query({{#if tenantDependent}}$tenantId: ID!, {{/if}}$first: Int) {
            all{{ pascalCase pluralName }}({{#if tenantDependent}}tenantId: $tenantId, {{/if}}first: $first) {
                edges {
                    node {
                        id
{{#if hasFields}}
{{#each fields}}
                        {{ name }}
{{/each}}
{{else}}
                        name
{{/if}}
                    }
                }
            }
        }
    '''

    def test_returns_{{ snakeCase pluralName }}_for_tenant(self, api_client: ApiClient):
{{#if tenantDependent}}
        tenant = TenantFactory()
        TenantMembershipFactory(user=api_client.user, tenant=tenant)
        {{ camelCase name }}1 = {{ pascalCase name }}Factory(tenant=tenant)
        {{ camelCase name }}2 = {{ pascalCase name }}Factory(tenant=tenant)
        other_tenant = TenantFactory()
        {{ pascalCase name }}Factory(tenant=other_tenant)  # Should not be returned
{{else}}
        {{ camelCase name }}1 = {{ pascalCase name }}Factory()
        {{ camelCase name }}2 = {{ pascalCase name }}Factory()
{{/if}}

        response = api_client.post_graphql(
            self.ALL_{{ constantCase pluralName }}_QUERY,
            {
{{#if tenantDependent}}
                'tenantId': to_global_id('TenantType', tenant.id),
{{/if}}
                'first': 10,
            },
        )

        edges = response['data']['all{{ pascalCase pluralName }}']['edges']
        assert len(edges) == 2
        ids = [edge['node']['id'] for edge in edges]
        assert to_global_id('{{ pascalCase name }}Type', {{ camelCase name }}1.id) in ids
        assert to_global_id('{{ pascalCase name }}Type', {{ camelCase name }}2.id) in ids


