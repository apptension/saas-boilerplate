import { {{ pascalCase name }}ListQueryQuery, getFragmentData, gql, pageCursorsFragment } from '@sb/webapp-api-client/graphql';
import { usePagedPaginatedQuery } from '@sb/webapp-api-client/hooks/usePagedPaginatedQuery';
import { ButtonVariant, Link } from '@sb/webapp-core/components/buttons';
import { PageLayout } from '@sb/webapp-core/components/pageLayout';
import { Paragraph } from '@sb/webapp-core/components/typography';
import { TableFooter } from '@sb/webapp-core/components/table';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@sb/webapp-core/components/ui/card';
import { useGenerateLocalePath } from '@sb/webapp-core/hooks';
import { mapConnection } from '@sb/webapp-core/utils/graphql';
import { useCurrentTenant } from '@sb/webapp-tenants/providers';
import { Database, Plus } from 'lucide-react';
import { Helmet } from 'react-helmet-async';
import { FormattedMessage, useIntl } from 'react-intl';

import { RoutesConfig } from '../../../app/config/routes';
import { {{ pascalCase name }}ListItem } from './{{ pascalCase name }}ListItem';
import { ListSkeleton } from './listSkeleton';

export const {{ pascalCase name }}ListQuery = gql(/* GraphQL */ `
  query {{ camelCase name }}ListQuery($tenantId: ID!, $first: Int, $after: String, $last: Int, $before: String) {
    all{{ pascalCase name }}s(tenantId: $tenantId, first: $first, after: $after, last: $last, before: $before) {
      edges {
        node {
          id
          ...{{ camelCase name }}ListItem
        }
      }
      pageCursors {
        ...pageCursorsFragment
      }
    }
  }
`);

type {{ pascalCase name }}ListSearchParams = {
  cursor?: string;
  pageSize?: string;
};

export const {{ pascalCase name }}List = () => {
  const intl = useIntl();
  const generateLocalePath = useGenerateLocalePath();
  const { data: currentTenant } = useCurrentTenant();

  const { data, loading, pageSize, onPageClick, handlePageSizeChange } = usePagedPaginatedQuery<
    {{ pascalCase name }}ListQueryQuery,
    { tenantId: string } & Omit<{{ pascalCase name }}ListSearchParams, 'cursor'>,
    {{ pascalCase name }}ListSearchParams,
    typeof {{ pascalCase name }}ListQuery
  >({{ pascalCase name }}ListQuery, {
    hookOptions: {
      variables: {
        tenantId: currentTenant?.id ?? '',
      },
      skip: !currentTenant,
    },
    dataKey: 'all{{ pascalCase name }}s',
  });
  const pageCursors = getFragmentData(pageCursorsFragment, data?.all{{ pascalCase name }}s?.pageCursors);

  const renderList = () => {
    if (data) {
      if (data.all{{ pascalCase name }}s && data.all{{ pascalCase name }}s.edges.length <= 0) return renderEmptyList();

      return (
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <Database className="h-5 w-5" />
              <FormattedMessage id="{{ pascalCase name }}List / Items title" defaultMessage="Items" />
            </CardTitle>
            <CardDescription>
              <FormattedMessage
                id="{{ pascalCase name }}List / Items description"
                defaultMessage="Manage your {{ pascalCase name }} items"
              />
            </CardDescription>
          </CardHeader>
          <CardContent className="p-0">
            <ul className="divide-y">
              {mapConnection(
                (node) => (
                  <{{ pascalCase name }}ListItem item={node} key={node.id} />
                ),
                data.all{{ pascalCase name }}s
              )}
            </ul>
          </CardContent>
        </Card>
      );
    }
    return null;
  };

  const renderEmptyList = () => {
    return (
      <Card>
        <CardContent className="py-16">
          <div className="flex flex-col items-center justify-center text-center">
            <Database className="h-12 w-12 text-muted-foreground mb-4" />
            <h3 className="text-lg font-semibold mb-2">
              <FormattedMessage id="{{ pascalCase name }}List / Empty title" defaultMessage="No items yet" />
            </h3>
            <p className="text-sm text-muted-foreground mb-4">
              <FormattedMessage
                id="{{ pascalCase name }}List / Empty description"
                defaultMessage="Get started by creating your first item"
              />
            </p>
            <Link
              to={generateLocalePath(RoutesConfig.{{ camelCase name }}.add)}
              variant={ButtonVariant.PRIMARY}
              className="gap-2"
            >
              <Plus className="h-4 w-4" />
              <FormattedMessage id="{{ pascalCase name }}List / Add first item" defaultMessage="Add your first item" />
            </Link>
          </div>
        </CardContent>
      </Card>
    );
  };

  return (
    <PageLayout>
      <Helmet
        title={intl.formatMessage({
          defaultMessage: '{{ pascalCase name }} Items',
          id: '{{ pascalCase name }}List / page title',
        })}
      />

      <div className="mx-auto w-full max-w-5xl space-y-8">
        {/* Hero Section */}
        <div className="space-y-4">
          <div className="flex items-center gap-2">
            <Database className="h-6 w-6 text-primary" />
            <h1 className="text-3xl font-bold tracking-tight">
              <FormattedMessage id="{{ pascalCase name }}List / Title" defaultMessage="{{ pascalCase name }} Items" />
            </h1>
          </div>
          <Paragraph className="text-lg text-muted-foreground">
            <FormattedMessage
              id="{{ pascalCase name }}List / Subheader"
              defaultMessage="Manage your {{ pascalCase name }} items"
            />
          </Paragraph>
        </div>

        {/* Actions */}
        <div className="flex justify-end">
          <Link
            to={generateLocalePath(RoutesConfig.{{ camelCase name }}.add)}
            variant={ButtonVariant.PRIMARY}
            className="gap-2"
          >
            <Plus className="h-4 w-4" />
            <FormattedMessage id="{{ pascalCase name }}List / Add new" defaultMessage="Add new item" />
          </Link>
        </div>

        {/* Content */}
        {loading ? (
          <ListSkeleton />
        ) : (
          <>
            {renderList()}
            {data?.all{{ pascalCase name }}s && data.all{{ pascalCase name }}s.edges.length > 0 && (
              <TableFooter
                pageSize={pageSize}
                pagination={{
                  around: pageCursors?.around,
                  first: pageCursors?.first,
                  last: pageCursors?.last,
                  next: pageCursors?.next,
                  previous: pageCursors?.previous,
                  onPageClick: onPageClick,
                }}
                onPageSizeChange={handlePageSizeChange}
              />
            )}
          </>
        )}
      </div>
    </PageLayout>
  );
};
