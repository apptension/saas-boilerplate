        </div>
      </PageLayout>
    );
  }

  if (!{{ camelCase name }}) return <Navigate to={generateLocalePath(RoutesConfig.{{ camelCase name }}.list)} />;

  const onFormSubmit = (formData: {{ pascalCase name }}FormFields) => {
    if (!currentTenant) return;
    commitEdit{{ pascalCase name }}Mutation({
      variables: { input: { tenantId: currentTenant.id, id: {{ camelCase name }}.id, name: formData.name } },
    });
  };

  return (
    <PageLayout>
      <Helmet
        title={intl.formatMessage({
