# =============================================================================
# WEB APPLICATION ENVIRONMENT CONFIGURATION - RENDER.COM
# =============================================================================
# This file contains the environment variables needed for Render.com deployment.
#
# Quick Start:
#   1. Deploy using the Blueprint (render.yaml) or manually create the static site
#   2. Set these variables in Render Dashboard → Environment Variables
#   3. Redeploy after setting variables (static sites need rebuild)
#
# Note: All variables must be prefixed with VITE_ to be accessible in the app
#
# For detailed guidance, see: packages/internal/docs/docs/deployment/render.mdx
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED (Set in Render Dashboard)
# -----------------------------------------------------------------------------

# Backend API URL - MUST include /api suffix
# Format: https://your-backend.onrender.com/api
# Example: https://backend-api-xxxx.onrender.com/api
VITE_BASE_API_URL=<YOUR_API_URL>/api

# Environment name (shown in UI for debugging)
VITE_ENVIRONMENT_NAME=production

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS (Required if using payments)
# -----------------------------------------------------------------------------
# Get from: Stripe Dashboard → Developers → API Keys

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
# This is the public key, safe to use in frontend code
VITE_STRIPE_PUBLISHABLE_KEY=<YOUR_STRIPE_PUBLISHABLE_KEY>

# -----------------------------------------------------------------------------
# CONTENTFUL CMS (Optional)
# -----------------------------------------------------------------------------
# Only needed if using Contentful for CMS features
# Get credentials from: https://app.contentful.com/

# Contentful Space ID
VITE_CONTENTFUL_SPACE=

# Contentful Content Delivery API token
VITE_CONTENTFUL_TOKEN=

# Contentful environment (develop, master, etc.)
VITE_CONTENTFUL_ENV=master

# -----------------------------------------------------------------------------
# MONITORING (Optional but Recommended)
# -----------------------------------------------------------------------------

# Sentry DSN for frontend error tracking
# Use the same project or a separate frontend project in Sentry
VITE_SENTRY_DSN=

# Google Analytics 4 Measurement ID (optional)
# VITE_GOOGLE_ANALYTICS_TRACKING_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# AUTHENTICATION FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Control which login methods are available on the login page
# All default to true if not set

# Enable enterprise SSO (SAML/OIDC) discovery
# VITE_ENABLE_SSO=true

# Enable passkey/WebAuthn authentication
# VITE_ENABLE_PASSKEYS=true

# Enable Google/Facebook social login buttons
# VITE_ENABLE_SOCIAL_LOGIN=true

# Enable email/password login form
# VITE_ENABLE_PASSWORD_LOGIN=true

# -----------------------------------------------------------------------------
# REMOTE TRANSLATIONS (Optional)
# -----------------------------------------------------------------------------
# Enable to load translations from CDN instead of bundled files

# Enable remote translations (true/false)
# VITE_USE_REMOTE_TRANSLATIONS=false

# Base URL for fetching translations
# VITE_TRANSLATIONS_URL=https://cdn.yourdomain.com/translations
